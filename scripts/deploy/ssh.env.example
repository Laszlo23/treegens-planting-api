# Copy to scripts/deploy/.env.ssh (gitignored) and fill in. Use SSH keys — not passwords in this file.
# See deploy/SSH-AUTH-AND-SECRETS.md

SSH_USER=root
SSH_HOST=your.vps.ip.or.hostname
SSH_PORT=22

# Remote path where the monorepo will live (no trailing slash)
REMOTE_DIR=/root/treegens-app

# Public API hostname (for docs only; Caddy uses the same name in deploy/caddy/Caddyfile.api.example)
API_DOMAIN=api.example.com
