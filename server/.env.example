# Copy to .env and adjust. Used by Pydantic Settings (server/app/config.py).

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/planting
JWT_SECRET=change-me-32-chars-minimum
SEED_USER_EMAIL=planter@example.com
SEED_USER_PASSWORD=change-me
INTERNAL_API_KEY=operator-secret-for-internal-routes

# Browser test UI at GET /ui/planting-test (set false in production)
ENABLE_PLANTING_TEST_UI=true

# MinIO (S3-compatible) — set S3_ENDPOINT_URL empty for real AWS S3
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=planting-media
S3_USE_SSL=false

# YOLO OBB weights (optional; API runs in stub mode if missing)
MODEL_PATH=/models/best.pt
MODEL_VERSION=1.0.0
# Ultralytics predict() confidence floor (not the same as MIN_TREE_CONFIDENCE policy filter)
YOLO_PREDICT_CONF=0.01
YOLO_IMGSZ=960
MIN_TREE_CONFIDENCE=0.25
MIN_TREES_DETECTED=1
HIGH_CONFIDENCE_THRESHOLD=0.5
REQUIRE_ANY_HIGH_CONFIDENCE=false
# Cross-frame unique estimate (normalized center distance 0–1)
# DEDUPE_CENTER_DISTANCE=0.08
MAX_CLOCK_SKEW_SECONDS=300

# Images: max per file (bytes) and per event — see max_images_per_event in config
# MAX_UPLOAD_BYTES=15728640

# Video (either/or with images per request)
# MAX_VIDEO_BYTES=209715200
# MAX_VIDEOS_PER_EVENT=3
# VIDEO_SAMPLE_FRAMES=12
# VIDEO_MAX_DURATION_SECONDS=120

# Optional planting region (WGS84)
# GEO_MIN_LAT=
# GEO_MAX_LAT=
# GEO_MIN_LON=
# GEO_MAX_LON=

# Roboflow (optional — reserved for dataset/model workflows; not used by default inference)
# ROBOFLOW_API_KEY=
# ROBOFLOW_PUBLISH_API_KEY=
