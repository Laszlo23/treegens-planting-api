# MongoDB Configuration
MONGODB_URI=mongodb://admin:password@localhost:27017/treegens?authSource=admin

# Pinata Configuration
PINATA_JWT=your_pinata_jwt
PINATA_GATEWAY_BASE_URL=https://gateway.pinata.cloud/ipfs

# Server Configuration
PORT=5000
NODE_ENV=development
API_BASE_URL=http://localhost:3000

# JWT Configuration (for future authentication)
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# Docker Setup (optional; only if you publish your own image)
# DOCKER_IMAGE=your-registry/treegens-backend:tag

# Public HTTPS origin of this API (CORS, links)—same host browsers use as NEXT_PUBLIC_API_URL
BACKEND_URL=https://tree.buildingculture.capital

BASE_SEPOLIA_RPC_URL=
# Optional fallback used by BASE_SEPOLIA_RPC_URL getter
RPC_URL=

TGN_TOKEN_ADDRESS=0xA10336e3e0ee9CC81397db91aC585BA32460Cdcf
DAO_CONTRACT_ADDRESS=0xe0Eb9FCfccEaA66edE66F5B94bfAdC1c90CeDc4D
MGRO_TOKEN_ADDRESS=0xE2507198a1C2cC0Fc6559159e2D86604a25bBE79
TGN_VAULT_ADDRESS=0x66e003F3318F13b122477E2561c1cf5C5181bc97
# Wallet with MGRO mint role (never commit real keys)
MGRO_MINTER_PRIVATE_KEY=
# Wallet authorized to call TGNVault.slash (never commit real keys)
TGN_VAULT_SLASHER_PRIVATE_KEY=
MGRO_DECIMALS=18
TGN_DECIMALS=18
# Reward vesting schedule defaults to every 6 months over 6 tranches (~3 years)
# Planter tranche timing config: total duration = MGRO_CLAIM_INTERVAL * MGRO_CLAIM_COUNT
MGRO_CLAIM_INTERVAL=15778800
MGRO_CLAIM_COUNT=6

TGN_STAKE_VERIFIER_CRON_TIME=

VALIDATORS_MINIMUM_TGN_TOKENS=2000n
MINIMUM_ACTIVE_VERIFIERS=5

ENABLE_CRONJOBS=true

# Reward claim queue worker (BullMQ + Redis)
ENABLE_REWARD_CLAIM_WORKER=false
# Slash queue worker (BullMQ + Redis)
ENABLE_SLASH_WORKER=false
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# Health check validation
# Max distance in meters between planted GPS and health-check GPS
HEALTH_CHECK_MAX_DISTANCE_METERS=5

# Planting proof API (FastAPI / server/) — REQUIRED for ML on every land/plant video upload
# After Pinata upload, Node POSTs the same video to FastAPI /internal/verify-video and stores mlVerification on the clip.
# Base URL with no trailing slash; must reach POST /internal/verify-video and /internal/verify-frame
PLANTING_VERIFICATION_API_URL=http://localhost:8000
# REQUIRED (non-empty): must match INTERNAL_API_KEY in FastAPI — without it uploads succeed but ML is skipped
PLANTING_VERIFICATION_INTERNAL_KEY=
# Optional: force on/off. If unset, ML runs when BOTH URL and INTERNAL_KEY above are non-empty
PLANTING_VERIFICATION_ENABLED=
# Axios timeout ms (YOLO + ffmpeg; default 180000)
PLANTING_VERIFICATION_TIMEOUT_MS=180000

# Standalone worker entrypoints (used by npm scripts)
RUN_REWARD_CLAIM_WORKER=false
RUN_SLASH_WORKER=false