{$BACKEND_URL} {
  route {
      @allowed {
          path /*
          remote_ip {$IP_WHITELIST}
      }
      reverse_proxy @allowed {
        to treegens-be1:5000 treegens-be2:5000
        lb_policy round_robin
        health_uri /health
        health_interval 5s
        health_timeout 2s
        health_status 200
      }
      respond 403
  }
}