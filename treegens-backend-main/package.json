{
  "name": "treegens-backend",
  "version": "1.0.0",
  "description": "Backend for Treegens proof of tree application",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "dev:worker": "RUN_REWARD_CLAIM_WORKER=true tsx watch src/workers/rewardClaimWorker.ts",
    "dev:slash-worker": "RUN_SLASH_WORKER=true tsx watch src/workers/slashWorker.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"./src\"",
    "lint:fix": "eslint \"./src\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "migrate": "node dist/scripts/migrate.js up",
    "migrate:down": "node dist/scripts/migrate.js down",
    "migrate:status": "node dist/scripts/migrate.js status",
    "test": "MONGODB_URI=${MONGODB_URI:-mongodb://127.0.0.1:27017/test} PINATA_JWT=test-pinata-jwt tsx --test src/**/*.test.ts",
    "start:worker": "RUN_REWARD_CLAIM_WORKER=true node dist/workers/rewardClaimWorker.js",
    "start:slash-worker": "RUN_SLASH_WORKER=true node dist/workers/slashWorker.js"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "bullmq": "^5.73.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "ethers": "^6.15.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "form-data": "^4.0.4",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.0",
    "@types/node-cron": "^3.0.11",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.40.0"
  },
  "keywords": [
    "video",
    "ipfs",
    "pinata",
    "mongodb",
    "express"
  ],
  "author": "Treegens Team",
  "license": "MIT",
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
