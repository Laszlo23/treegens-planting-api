# --- Production / 4everland: set all NEXT_PUBLIC_* before `yarn build:ipfs` (or STATIC_EXPORT=true yarn build) ---
# See `deploy/DEVELOPER-HANDOFF.md`, `deploy/4EVERLAND.md`, `deploy/IPFS-FREENAME-DEPLOY.md`.

# Public Node/Express API (no trailing slash). Production: https://tree.buildingculture.capital — not the 4everland static URL.
# Local: http://localhost:5000 (or leave unset in development — see src/config/publicApiUrl.ts)
NEXT_PUBLIC_API_URL=https://tree.buildingculture.capital
NEXT_PUBLIC_IPFS_GATEWAY=
# Required for real wallet flows; if unset, a build placeholder is used (see src/config/thirdwebConfig.ts)
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
NEXT_PUBLIC_NODE_ENV=development    #Will enable Eruda and Base Sepolia
# Defaults match mobile `constants/thirdweb.ts` if left empty
NEXT_PUBLIC_TGN_VAULT_ADDRESS=
NEXT_PUBLIC_TGN_TOKEN_ADDRESS=
NEXT_PUBLIC_TGN_TOKEN_DECIMALS=
NEXT_PUBLIC_VALIDATORS_MINIMUM_TGN_TOKENS=2000
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=